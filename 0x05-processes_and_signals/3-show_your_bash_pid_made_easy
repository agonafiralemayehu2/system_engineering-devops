#!/bin/bash
# Display PID and process name for processes containing bash without using ps
for pid in $(ls /proc | grep '^[0-9]\+$'); do
    if [ -f /proc/$pid/comm ]; then
        comm=$(cat /proc/$pid/comm)
        if [[ "$comm" == *bash* ]]; then
            echo "$pid $comm"
        fi
    fi
done
